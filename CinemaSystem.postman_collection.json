{
    "info": {
        "name": "Cinema System API",
        "description": "API collection for Cinema System microservices",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{accessToken}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "https://localhost:7001",
            "type": "string"
        },
        {
            "key": "movieApiUrl",
            "value": "https://localhost:7002",
            "type": "string"
        },
        {
            "key": "cinemaApiUrl",
            "value": "https://localhost:7003",
            "type": "string"
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "refreshToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "userId",
            "value": "",
            "type": "string"
        },
        {
            "key": "movieId",
            "value": "",
            "type": "string"
        },
        {
            "key": "cinemaHallId",
            "value": "",
            "type": "string"
        },
        {
            "key": "showtimeId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Identity API",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    if (response.success && response.data.userId) {",
                                    "        pm.collectionVariables.set('userId', response.data.userId);",
                                    "        console.log('User registered with ID:', response.data.userId);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@cinema.com\",\n  \"password\": \"Customer123\",\n  \"fullName\": \"John Doe\",\n  \"phoneNumber\": \"0123456789\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    if (response.success && response.data) {",
                                    "        pm.collectionVariables.set('accessToken', response.data.accessToken);",
                                    "        pm.collectionVariables.set('refreshToken', response.data.refreshToken);",
                                    "        pm.collectionVariables.set('userId', response.data.userId);",
                                    "        console.log('Login successful!');",
                                    "        console.log('Access Token:', response.data.accessToken);",
                                    "        console.log('Refresh Token:', response.data.refreshToken);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@cinema.com\",\n  \"password\": \"Customer123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Current User (Me)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        },
                        "description": "Protected endpoint - requires valid JWT token"
                    },
                    "response": []
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const response = pm.response.json();",
                                    "    if (response.success && response.data) {",
                                    "        pm.collectionVariables.set('accessToken', response.data.accessToken);",
                                    "        pm.collectionVariables.set('refreshToken', response.data.refreshToken);",
                                    "        console.log('Token refreshed successfully!');",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/refresh-token",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "refresh-token"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Revoke Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/revoke-token",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "revoke-token"
                            ]
                        },
                        "description": "Protected endpoint - requires valid JWT token"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Movie API - Showtimes",
            "item": [
                {
                    "name": "Get Showtime by ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/{{showtimeId}}",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "{{showtimeId}}"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Showtimes by Movie ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/movie/{{movieId}}",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "movie",
                                "{{movieId}}"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Showtimes by Cinema Hall ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/cinemahall/{{cinemaHallId}}",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "cinemahall",
                                "{{cinemaHallId}}"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Upcoming Showtimes",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/upcoming?count=20",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "upcoming"
                            ],
                            "query": [
                                {
                                    "key": "count",
                                    "value": "20"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Create Showtime",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    const response = pm.response.json();",
                                    "    if (response.data && response.data.id) {",
                                    "        pm.collectionVariables.set('showtimeId', response.data.id);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"movieId\": \"{{movieId}}\",\n  \"cinemaHallId\": \"{{cinemaHallId}}\",\n  \"startTime\": \"2026-04-28T14:00:00Z\",\n  \"price\": 150000\n}"
                        },
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Showtime",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"startTime\": \"2026-04-28T15:00:00Z\",\n  \"price\": 180000\n}"
                        },
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/{{showtimeId}}",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "{{showtimeId}}"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Delete Showtime",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{movieApiUrl}}/api/showtimes/{{showtimeId}}",
                            "host": [
                                "{{movieApiUrl}}"
                            ],
                            "path": [
                                "api",
                                "showtimes",
                                "{{showtimeId}}"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ]
}