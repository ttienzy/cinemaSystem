{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BookingConnection": "Server=YOUR_SERVER;Database=BookingText;User=sa;Password=YOUR_PASSWORD;Trusted_Connection=True;TrustServerCertificate=true",
    "IdentityConnection": "Server=YOUR_SERVER;Database=IdentityTest;User=sa;Password=YOUR_PASSWORD;Trusted_Connection=True;TrustServerCertificate=true",
    "RedisConnection": "127.0.0.1:6379"
  },
  "Jwt": {
    "Issuer": "BookingApi",
    "Audience": "BookingApiUsers",
    "SecretKey": "YOUR_SUPER_SECRET_KEY_HERE_AT_LEAST_32_CHARACTERS",
    "AccessTokenExpiration": 20,
    "RefreshTokenExpiration": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateIssuerSigningKey": true
  },
  "Smtp": {
    "Server": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "DEMO_SENDER",
    "SenderEmail": "demo_email@gmail.com",
    "Username": "demo_email@gmail.com",
    "Password": "demo_app_password"
  },
  "Vnpay": {
    "vnp_TmnCode": "YOUR_TMN_CODE",
    "HashSecret": "YOUR_HASH_SECRET",
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "vnp_Command": "pay",
    "vnp_CurrCode": "VND",
    "vnp_Version": "2.1.0",
    "vnp_Locale": "vn"
  },
  "PaymentCallBack": {
    "vnp_ReturnUrl": "https://localhost:7227/api/Bookings/callback"
  },
  "TimeZone": {
    "Id": "SE Asia Standard Time"
  }
}
