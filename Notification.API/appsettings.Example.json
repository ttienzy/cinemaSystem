{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "rabbitmq": "amqp://YOUR_RABBITMQ_USER:YOUR_RABBITMQ_PASSWORD@YOUR_RABBITMQ_HOST:5672"
  },
  "MassTransit": {
    "PrefetchCount": 16,
    "RetryLimit": 3,
    "RetryIntervalSeconds": 5
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_APP_PASSWORD",
    "FromEmail": "noreply@cinema-system.com",
    "FromName": "CinemaSystem",
    "TimeoutSeconds": 30
  }
}
