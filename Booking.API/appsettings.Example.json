{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Cinema.EventBusRabbitMQ": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "booking-db": "Server=YOUR_SQL_HOST,1433;Database=Db_Booking;User Id=sa;Password=YOUR_SQL_PASSWORD;TrustServerCertificate=True;",
    "redis": "YOUR_REDIS_HOST:6379",
    "rabbitmq": "amqp://YOUR_RABBITMQ_USER:YOUR_RABBITMQ_PASSWORD@YOUR_RABBITMQ_HOST:5672"
  },
  "ServiceUrls": {
    "CinemaApi": "https://localhost:7251",
    "MovieApi": "https://localhost:7295",
    "PaymentApi": "https://localhost:7252"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "CinemaSystem.Identity",
    "Audience": "CinemaSystem.Clients",
    "ExpirationMinutes": 60
  },
  "EventBus": {
    "RetryCount": 5,
    "BrokerName": "cinema_event_bus",
    "QueueName": "booking-api-queue"
  },
  "SeatLock": {
    "LockDurationMinutes": 10,
    "CleanupIntervalMinutes": 1
  },
  "Redis": {
    "KeyPrefix": "cinema",
    "SeatMapExpirationHours": 24,
    "SignalRChannelPrefix": "cinema:signalr"
  },
  "Booking": {
    "ExpirationMinutes": 10,
    "MaxSeatsPerBooking": 10,
    "MinutesBeforeShowtimeToBook": 30
  },
  "BackgroundServices": {
    "CleanupIntervalMinutes": 1,
    "EnableCleanupService": true
  },
  "SignalR": {
    "EnableDetailedErrors": true,
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutIntervalSeconds": 30,
    "HandshakeTimeoutSeconds": 15,
    "MaximumReceiveMessageSize": 32768
  },
  "Features": {
    "EnableSignalRBroadcasts": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173"
    ]
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_APP_PASSWORD",
    "FromEmail": "noreply@cinema-system.com",
    "FromName": "CinemaSystem",
    "TimeoutSeconds": 30
  }
}
