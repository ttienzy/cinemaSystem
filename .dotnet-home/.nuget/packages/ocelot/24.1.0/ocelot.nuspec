    <repository type="git" url="https://github.com/ThreeMammals/Ocelot.git" commit="9fc4e78d314ad97d836b35c9b9bb188dba49d556" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="FluentValidation" version="12.1.1" exclude="Build,Analyzers" />
        <dependency id="IPAddressRange" version="6.3.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.MiddlewareAnalysis" version="8.0.22" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.Mvc.NewtonsoftJson" version="8.0.22" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DiagnosticAdapter" version="3.1.32" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="FluentValidation" version="12.1.1" exclude="Build,Analyzers" />
        <dependency id="IPAddressRange" version="6.3.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.MiddlewareAnalysis" version="9.0.11" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.Mvc.NewtonsoftJson" version="9.0.11" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DiagnosticAdapter" version="3.1.32" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>