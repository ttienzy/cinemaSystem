{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BookingConnection": "Server=YOUR_SERVER;Database=Booking;User=YOUR_USER;Password=YOUR_PASSWORD;Trusted_Connection=True;TrustServerCertificate=true",
    "IdentityConnection": "Server=YOUR_SERVER;Database=Identity;User=YOUR_USER;Password=YOUR_PASSWORD;Trusted_Connection=True;TrustServerCertificate=true",
    "RedisConnection": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "CinemaApi",
    "Audience": "CinemaApiUsers",
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS_LONG",
    "AccessTokenExpiration": 20,
    "RefreshTokenExpiration": 7,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateIssuerSigningKey": true
  },
  "Smtp": {
    "Server": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "Cinema System Admin",
    "SenderEmail": "noreply@yourdomain.local",
    "Username": "YOUR_EMAIL@gmail.com",
    "Password": "YOUR_APP_PASSWORD"
  },
  "Vnpay": {
    "vnp_TmnCode": "YOUR_TMN_CODE",
    "HashSecret": "YOUR_HASH_SECRET",
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "vnp_Command": "pay",
    "vnp_CurrCode": "VND",
    "vnp_Version": "2.1.0",
    "vnp_Locale": "vn"
  },
  "PaymentCallBack": {
    "vnp_ReturnUrl": "http://localhost:8080/api/Bookings/callback"
  },
  "TimeZone": {
    "Id": "SE Asia Standard Time"
  }
}
