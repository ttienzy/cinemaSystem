# Reference only: copy the appsettings.Example.json files inside each service
# when you need local secrets. This file documents shared environment values.

# Shared JWT configuration
JWT_SECRET=your-super-secret-key-that-is-at-least-32-characters-long!
JWT_ISSUER=CinemaSystem.Identity
JWT_AUDIENCE=CinemaSystem.Clients

# Docker / infrastructure
MSSQL_SA_PASSWORD=YourStrong@Passw0rd123
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Payment.API / SePay
SEPAY_MERCHANT_ID=your-sepay-merchant-id
SEPAY_SECRET_KEY=your-sepay-secret-key
SEPAY_ENVIRONMENT=sandbox
SEPAY_IPN_URL=https://your-ngrok-url.ngrok-free.dev/api/payments/sepay/ipn

# Booking.API / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@cinema-system.com
SMTP_FROM_NAME=Cinema System

# Movie.API / Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
