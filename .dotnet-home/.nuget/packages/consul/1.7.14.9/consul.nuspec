<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Consul</id>
    <version>1.7.14.9</version>
    <authors>PlayFab,G-Research</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <projectUrl>https://consuldot.net/</projectUrl>
    <description>Consul.NET is a .NET client library for the Consul HTTP API</description>
    <releaseNotes>https://github.com/G-Research/consuldotnet/blob/master/CHANGELOG.md</releaseNotes>
    <copyright>Copyright 2015-2018 PlayFab Inc.; Copyright 2020-2025 G-Research Limited</copyright>
    <tags>Consul service discovery distributed locking health checking</tags>
    <repository type="git" url="https://github.com/G-Research/consuldotnet" commit="2e78fd4c6ca594f709120d1712d0c8d3986202c5" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.1">
        <dependency id="Microsoft.CSharp" version="4.7.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.CSharp" version="4.7.0" exclude="Build,Analyzers" />
        <dependency id="Newtonsoft.Json" version="13.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.Net.Http" targetFramework=".NETFramework4.6.1" />
      <frameworkAssembly assemblyName="System.Net.Http.WebRequest" targetFramework=".NETFramework4.6.1" />
    </frameworkAssemblies>
  </metadata>
</package>