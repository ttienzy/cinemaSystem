      "DownstreamScheme": "http",
      "ServiceName": "movie-api",
      "Key": "movies-read",
      "FileCacheOptions": {
        "TtlSeconds": 300,
        "Region": "movies"
      },
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
