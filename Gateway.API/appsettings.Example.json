{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "CinemaSystem.Identity",
    "Audience": "CinemaSystem.Clients",
    "ExpirationMinutes": 60
  },
  "Gateway": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:4200",
        "http://localhost:5173",
        "https://localhost:3000",
        "https://localhost:4200",
        "https://localhost:5173",
        "https://cinema-app.com",
        "https://www.cinema-app.com"
      ]
    },
    "Cache": {
      "Redis": {
        "Enabled": true,
        "ConnectionString": "YOUR_REDIS_HOST:6379",
        "Database": 0,
        "EnableKeyspaceNotifications": false,
        "MaxRetries": 100,
        "RetryTimeoutMs": 50
      }
    },
    "ServiceDiscovery": {
      "Enabled": false
    }
  }
}
